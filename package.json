{
  "name": "@octane-rl/react",
  "version": "0.0.4",
  "publishConfig": {
    "access": "public"
  },
  "description": "Contains React Hooks that offer an intuitive and ergonomic way to integrate the Octane Rocket League overlay into React applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@octane-rl/core": "0.0.5",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "react-dom": "^19.2.5",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
